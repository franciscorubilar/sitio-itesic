# ==================== SERVIDOR ====================
NODE_ENV=production
PORT=3000
DATABASE_URL=postgresql://itesicws:itesicws123@postgres:5432/itesicws?schema=public
SESSION_SECRET=cambia-este-secret-en-produccion
APP_URL=http://localhost:3000

# ==================== EMAIL/SMTP ====================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu-email@gmail.com
SMTP_PASS=tu-contraseña-aplicacion
SMTP_FROM=ITESICWS <no-reply@itesicws.cl>
SMTP_SECURE=false

# ==================== CHATBOT IA (ELIGE UNA OPCIÓN) ====================

# ✅ OPCIÓN 1: DEEPSEEK (Recomendado - barato)
# Consigue key en: https://platform.deepseek.com
CHATBOT_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=tu_api_key_deepseek
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
CHATBOT_AI_ENABLED=true

# ✅ OPCIÓN 2: OPENAI (Más inteligente)
# Consigue key en: https://platform.openai.com/account/api-keys
# OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx
# CHATBOT_AI_PROVIDER=openai
# OPENAI_MODEL=gpt-4o-mini
# CHATBOT_AI_ENABLED=true

# ✅ OPCIÓN 3: HYBRID (Usa ambas)
# CHATBOT_AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=tu_api_key_deepseek
# DEEPSEEK_MODEL=deepseek-chat
# OPENAI_API_KEY=sk-proj-openai-xxxx
# CHATBOT_AI_ENABLED=true

# ✅ OPCIÓN 4: SIN IA (Solo reglas locales + fuzzy matching)
# CHATBOT_AI_ENABLED=false

# Vector Store (si usas OpenAI Files API)
OPENAI_VECTOR_STORE_ID=

# Reasoning effort (low, medium, high)
OPENAI_REASONING_EFFORT=low
