<%- include('partials/header') %>

<!-- ═══════════════════════ HERO — HIGH IMPACT ═══════════════════════ -->
<section class="cia-hero-section">
  <div class="cia-hero-decorations" aria-hidden="true">
    <div class="cia-glow glow-primary"></div>
    <div class="cia-glow glow-accent"></div>
    <div class="cia-grid-bg"></div>
  </div>

  <div class="cia-hero-container">
    <!-- Columna Izquierda: Mensaje y Propuesta -->
    <div class="cia-hero-left reveal">
      <div class="cia-tag-badge">
        <svg class="cia-pulse-dot" viewBox="0 0 100 100">
          <circle cx="50" cy="50" r="30" fill="currentColor" />
          <circle cx="50" cy="50" r="30" fill="none" stroke="currentColor" stroke-width="10">
            <animate attributeName="r" values="30;48;30" dur="2s" repeatCount="indefinite" />
            <animate attributeName="opacity" values="1;0;1" dur="2s" repeatCount="indefinite" />
          </circle>
        </svg>
        <span>Consultoría IA para Empresas</span>
      </div>

      <h1 class="cia-title" data-split-title>IA real conectada a la operación de tu negocio</h1>
      <p class="cia-subtitle">Construimos asistentes internos, automatización de documentos y agentes IA integrados a tus bases de datos, PDFs e informes de producción. Soluciones diseñadas para resolver ineficiencias concretas.</p>

      <!-- Trust Badges de Industrias -->
      <div class="cia-industry-chips">
        <span class="cia-chip-title">Experiencia real en:</span>
        <div class="cia-chips-row">
          <span class="cia-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>
            Logística
          </span>
          <span class="cia-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/></svg>
            Retail
          </span>
          <span class="cia-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
            Calibraciones
          </span>
          <span class="cia-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/></svg>
            Minería
          </span>
          <span class="cia-chip">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="chip-icon"><path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 2.7 3.5 6 3.5s6-1.5 6-3.5v-5"/></svg>
            Educación
          </span>
        </div>
      </div>

      <div class="cia-hero-buttons">
        <a class="btn primary cia-btn-glow" href="/?interest=<%= encodeURIComponent('Consultoría IA') %>#contacto">
          <span>Solicitar diagnóstico sin costo</span>
        </a>
        <a class="btn ghost" href="#casos-ia">
          <span>Ver casos de uso ↓</span>
        </a>
      </div>
    </div>

    <!-- Columna Derecha: gráfico operacional sobrio -->
    <div class="cia-hero-right reveal delay" data-parallax-stage>
      <div class="cia-visual-frame">
        <img class="cia-brain-img" data-theme-product-image data-light-src="/images/consultoria-ia-dark.png" data-dark-src="/images/consultoria-ia-light.png" src="/images/consultoria-ia-dark.png" alt="Consultoría IA aplicada a procesos y datos corporativos">
        
        <!-- Tarjeta Flotante 1: RAG Corporativo -->
        <div class="float-card cia-fc cia-fc-1">
          <div class="cia-fc-glow"></div>
          <div class="cia-fc-icon-wrapper red">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
          </div>
          <div class="cia-fc-info">
            <b>RAG Documental</b>
            <span>Consulta manuales, contratos e informes internos.</span>
          </div>
        </div>

        <!-- Tarjeta Flotante 2: Integraciones y Agentes -->
        <div class="float-card cia-fc cia-fc-2">
          <div class="cia-fc-glow"></div>
          <div class="cia-fc-icon-wrapper green">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
          </div>
          <div class="cia-fc-info">
            <b>Agentes Autónomos</b>
            <span>Acciones automatizadas conectadas a tu ERP y APIs.</span>
          </div>
        </div>

        <!-- Tarjeta Flotante 3: BI y Datos -->
        <div class="float-card cia-fc cia-fc-3">
          <div class="cia-fc-glow"></div>
          <div class="cia-fc-icon-wrapper blue">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          </div>
          <div class="cia-fc-info">
            <b>BI con Lenguaje Natural</b>
            <span>Pregunta KPIs diarios en simple y obtén respuestas directas.</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Métricas Rápidas -->
  <div class="cia-metrics-bar reveal">
    <div class="cia-metric-card">
      <div class="cia-metric-number"><span data-count="30">0</span>días</div>
      <div class="cia-metric-label">Tiempo promedio para un primer piloto funcional</div>
    </div>
    <div class="cia-metric-card">
      <div class="cia-metric-number">100%</div>
      <div class="cia-metric-label">Enfocado en tu operación real, sin teorías</div>
    </div>
    <div class="cia-metric-card">
      <div class="cia-metric-number"><span data-count="5">0</span>frentes</div>
      <div class="cia-metric-label">De automatización listos para ser aplicados</div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ COMPARATIVA: ELIMINAR HUMO ═══════════════════════ -->
<section class="section cia-comparison-section reveal">
  <div class="center">
    <span class="eyebrow">Diferencia Clave</span>
    <h2>Entendemos la diferencia entre tecnología útil y humo publicitario</h2>
    <p class="section-lead">Un chat genérico que no conoce tu stock, ni tus clientes, ni tus facturas no soluciona el problema de fondo. Construimos soluciones de datos que entienden tu negocio.</p>
  </div>

  <div class="cia-comparison-grid">
    <div class="cia-comparison-card negative">
      <div class="cia-card-header">
        <svg class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        <h3>La IA genérica (De humo)</h3>
      </div>
      <ul class="cia-comparison-list">
        <li>❌ Chatbots aislados que inventan respuestas ("alucinación").</li>
        <li>❌ No se conecta a tus sistemas internos ni a tu base de datos histórica.</li>
        <li>❌ Depende de copiar y pegar información manualmente cada vez.</li>
        <li>❌ Solución estándar que no considera las reglas de tu operación.</li>
        <li>❌ Costos impredecibles y riesgos de privacidad con datos corporativos.</li>
      </ul>
    </div>

    <div class="cia-comparison-card positive">
      <div class="cia-card-header">
        <svg class="header-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
        <h3>Nuestra IA Aplicada (De operación)</h3>
      </div>
      <ul class="cia-comparison-list">
        <li>✅ Respuestas con trazabilidad y cita exacta del documento fuente.</li>
        <li>✅ Conexión directa vía APIs seguras a tu ERP, planillas e informes.</li>
        <li>✅ Automatizaciones integradas que ejecutan flujos de trabajo completos.</li>
        <li>✅ Adaptación a los procesos chilenos de Logística, Retail y Minería.</li>
        <li>✅ Datos protegidos en tu propio servidor o nube privada.</li>
      </ul>
    </div>
  </div>
</section>

<!-- ═══════════════════════ CASOS DE USO REALES ═══════════════════════ -->
<section id="casos-ia" class="section cia-cases-section reveal">
  <div class="center">
    <span class="eyebrow">Casos Prácticos</span>
    <h2>Dónde aplicamos Inteligencia Artificial en el día a día</h2>
    <p class="section-lead">Transformamos el trabajo manual lento en flujos automáticos y controlados.</p>
  </div>

  <div class="cia-cases-container">
    <!-- Caso 1 -->
    <div class="cia-usecase-card">
      <div class="cia-uc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
      </div>
      <h3>Asistente de Contratos y Documentos</h3>
      <p>Un sistema de RAG corporativo que permite a tu equipo buscar en segundos cláusulas específicas de contratos históricos, manuales de calibración o normativas mineras de la SMA/DGA, citando la página exacta para evitar errores.</p>
      <div class="cia-uc-highlight">Evita buscar a mano en cientos de carpetas PDF.</div>
    </div>

    <!-- Caso 2 -->
    <div class="cia-usecase-card">
      <div class="cia-uc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22 6 12 13 2 6"/></svg>
      </div>
      <h3>Automatización y Clasificación de Emails</h3>
      <p>Agentes de IA que leen la bandeja de entrada de soporte o cotizaciones, clasifican la urgencia, extraen datos claves (RUT, número de orden, monto) y los cargan automáticamente en el ERP, redactando un borrador de respuesta listo para revisión.</p>
      <div class="cia-uc-highlight">Baja el tiempo de procesamiento de correos en un 70%.</div>
    </div>

    <!-- Caso 3 -->
    <div class="cia-usecase-card">
      <svg class="cia-uc-badge-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <div class="cia-uc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
      </div>
      <h3>Generador Automático de Informes</h3>
      <p>Extrae y procesa datos crudos provenientes de maquinaria, planillas de pesaje u órdenes de retail. La IA consolida los resultados, identifica anomalías y escribe un informe técnico resumido listo para ser firmado por el supervisor.</p>
      <div class="cia-uc-highlight">Ideal para reportes de turno y minutas de calibración.</div>
    </div>

    <!-- Caso 4 -->
    <div class="cia-usecase-card">
      <div class="cia-uc-icon">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
      </div>
      <h3>Consultas a Bases de Datos con Lenguaje Natural</h3>
      <p>Permite que gerentes y directores pregunten KPIs en lenguaje simple a través de una interfaz segura: <i>"¿Cuál fue el margen de despacho de la sucursal Norte la semana pasada?"</i>. La IA genera el SQL interno, extrae los datos y responde de inmediato.</p>
      <div class="cia-uc-highlight">Sin esperar que el equipo de TI prepare un reporte especial.</div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ ROADMAP DE IMPLEMENTACIÓN ═══════════════════════ -->
<section class="cia-roadmap-container reveal">
  <div class="cia-roadmap-header">
    <span class="eyebrow">Nuestro Proceso</span>
    <h2>Cómo llevamos la IA a tu operación sin enredos</h2>
    <p>Trabajamos de forma ágil, reduciendo el riesgo de inversión a través de fases claras y entregas funcionales rápidas.</p>
  </div>

  <div class="cia-roadmap-timeline">
    <div class="cia-roadmap-line-connector"></div>
    
    <div class="cia-roadmap-step-card">
      <div class="cia-step-circle">1</div>
      <div class="cia-step-info">
        <h3>Diagnóstico Inicial</h3>
        <p>Analizamos las planillas, reportes y sistemas que hoy quitan más tiempo. Identificamos los flujos con mayor potencial de automatización inmediata.</p>
      </div>
    </div>

    <div class="cia-roadmap-step-card">
      <div class="cia-step-circle">2</div>
      <div class="cia-step-info">
        <h3>Arquitectura y Presupuesto</h3>
        <p>Definimos qué modelos usar, el volumen de datos a indexar, las integraciones necesarias y proyectamos los costos de consumo de APIs (OpenAI/Azure) de forma transparente.</p>
      </div>
    </div>

    <div class="cia-roadmap-step-card">
      <div class="cia-step-circle">3</div>
      <div class="cia-step-info">
        <h3>Piloto Funcional (Mínimo Viable)</h3>
        <p>En un plazo máximo de 3 a 4 semanas entregamos un prototipo funcional conectado a tus datos reales para que tu equipo pueda probar el impacto y dar feedback rápido.</p>
      </div>
    </div>

    <div class="cia-roadmap-step-card">
      <div class="cia-step-circle">4</div>
      <div class="cia-step-info">
        <h3>Escalabilidad e Integración</h3>
        <p>Conectamos la solución al flujo diario de la empresa. Agregamos políticas de gobernanza, seguridad de datos, auditoría de tokens y logs de uso.</p>
      </div>
    </div>
  </div>
</section>

<!-- ═══════════════════════ STACK TECNOLÓGICO SEGURO ═══════════════════════ -->
<section class="section cia-architecture-section reveal">
  <div class="cia-arch-split">
    <!-- Izquierda: Visual e Interactivo -->
    <div class="cia-arch-visual-col" data-parallax-stage>
      <div class="cia-arch-media-frame">
        <img class="cia-arch-img" src="/images/brand-architecture.svg" alt="Arquitectura ITESICWS del flujo de datos con IA">
        
        <!-- Chips interactivos flotantes -->
        <span class="stack-chip cia-sc cia-sc-1">Azure OpenAI / API</span>
        <span class="stack-chip cia-sc cia-sc-2">RAG / LangChain</span>
        <span class="stack-chip cia-sc cia-sc-3">PostgreSQL Vector</span>
        <span class="stack-chip cia-sc cia-sc-4">Docker Deployment</span>
        <span class="stack-chip cia-sc cia-sc-5">Power BI integration</span>
      </div>
    </div>

    <!-- Derecha: Texto y Listado -->
    <div class="cia-arch-text-col">
      <span class="eyebrow">Arquitectura Conectada</span>
      <h2>IA integrada a tu infraestructura actual</h2>
      <p>No creamos herramientas aisladas. Creamos integraciones que respetan tu stack de software existente y garantizan la privacidad de tu información corporativa.</p>
      
      <ul class="cia-arch-bullets">
        <li>
          <div class="cia-bullet-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          </div>
          <div>
            <h4>Privacidad garantizada</h4>
            <p>Tus datos no se usan para entrenar modelos públicos. Toda la información permanece en entornos corporativos seguros.</p>
          </div>
        </li>
        <li>
          <div class="cia-bullet-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><polyline points="17 11 19 13 23 9"/></svg>
          </div>
          <div>
            <h4>Fácil adopción para el equipo</h4>
            <p>Diseñamos interfaces intuitivas directamente en la web o integradas a herramientas de comunicación interna y de oficina.</p>
          </div>
        </li>
        <li>
          <div class="cia-bullet-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>
          </div>
          <div>
            <h4>Trazabilidad y control</h4>
            <p>Monitoreamos el consumo, el costo por consulta y registramos logs de trazabilidad para auditar el comportamiento de los agentes.</p>
          </div>
        </li>
      </ul>
    </div>
  </div>
</section>

