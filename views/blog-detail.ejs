<%- include('partials/header') %>

<div class="reading-progress" data-reading-progress></div>
<article class="blog-detail">
  <header class="blog-detail-hero">
    <div>
      <span class="eyebrow"><%= post.category.name %></span>
      <h1><%= post.title %></h1>
      <p><%= post.excerpt %></p>
      <small><%= formatDate(post.publishedAt) %> · <%= post.readMinutes %> min de lectura · <%= post.author %></small>
    </div>
    <img src="<%= post.image %>" alt="<%= post.title %>">
  </header>

  <div class="blog-detail-layout">
    <aside class="article-side-card">
      <span class="eyebrow">En esta guía</span>
      <div data-article-toc class="article-toc"></div>
      <a class="btn primary" href="/?interest=<%= encodeURIComponent(post.category.name) %>#contacto"><span>Quiero aplicar esto</span></a>
      <button class="btn ghost" type="button" data-copy-link><span>Copiar enlace</span></button>
    </aside>
    <section class="blog-article-body ql-editor" data-article-body>
      <%- renderBlogContent(post.content) %>
    </section>
  </div>

  <section class="article-conversion-card reveal">
    <div>
      <span class="eyebrow">Siguiente paso</span>
      <h2>¿Quieres llevar esta idea a un sistema real?</h2>
      <p>Podemos ayudarte a convertir el proceso en una aplicación, dashboard, chatbot o automatización concreta para tu operación.</p>
    </div>
    <div class="article-conversion-actions">
      <a class="btn primary" href="/#contacto"><span>Solicitar diagnóstico</span></a>
      <a class="btn ghost" href="<%= whatsappUrl(settings.whatsappNumber, 'Hola ITESICWS, leí el artículo: ' + post.title + ' y quiero conversar.') %>" target="_blank" rel="noopener"><span>WhatsApp</span></a>
    </div>
  </section>

  <% if (post.faqs && post.faqs.length) { %>
    <section class="section blog-detail-faq">
      <div class="section-head">
        <div>
          <span class="eyebrow">Preguntas frecuentes</span>
          <h2>Dudas sobre este tema</h2>
        </div>
      </div>
      <div class="faq">
        <% post.faqs.forEach(faq => { %>
          <details>
            <summary><%= faq.question %></summary>
            <p><%= faq.answer %></p>
          </details>
        <% }) %>
      </div>
    </section>
  <% } %>
</article>

<% if (relatedPosts.length) { %>
  <section class="section reveal">
    <div class="section-head">
      <div>
        <span class="eyebrow">Relacionado</span>
        <h2>Más en <%= post.category.name %></h2>
      </div>
      <a class="btn ghost" href="/blog"><span>Ver blog</span></a>
    </div>
    <div class="blog-grid">
      <% relatedPosts.forEach(related => { %>
        <a class="blog-card" href="/blog/<%= related.slug %>">
          <img src="<%= related.image %>" alt="<%= related.title %>">
          <span><%= related.category.name %></span>
          <h3><%= related.title %></h3>
          <p><%= related.excerpt %></p>
        </a>
      <% }) %>
    </div>
  </section>
<% } %>

<%- include('partials/footer') %>
