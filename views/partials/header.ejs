<!doctype html>
<html lang="es" data-theme="light">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle : settings.siteName + ' - Software empresarial e IA' %></title>
  <meta name="description" content="<%= typeof pageDescription !== 'undefined' ? String(pageDescription).replace(/<[^>]*>/g, ' ').slice(0, 155) : 'Software empresarial, consultoría IA, automatización, Power BI y plataformas operacionales.' %>" />
  <meta property="og:title" content="<%= typeof pageTitle !== 'undefined' ? pageTitle : settings.siteName + ' - Software empresarial e IA' %>" />
  <meta property="og:description" content="<%= typeof pageDescription !== 'undefined' ? String(pageDescription).replace(/<[^>]*>/g, ' ').slice(0, 155) : 'Software empresarial, consultoría IA, automatización, Power BI y plataformas operacionales.' %>" />
  <link rel="icon" href="/images/logos/icon.svg" type="image/svg+xml" />
  <link rel="icon" href="/images/logos/favicon-32.png" type="image/png" sizes="32x32" />
  <link rel="icon" href="/images/logos/favicon-16.png" type="image/png" sizes="16x16" />
  <link rel="shortcut icon" href="/images/logos/favicon.ico" />
  <link rel="apple-touch-icon" href="/images/logos/icon-256.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Sora:wght@500;600;700;800&display=swap" rel="stylesheet">
  <% if (path.startsWith('/admin/blog')) { %>
    <link rel="stylesheet" href="/vendor/quill/quill.snow.css" />
  <% } %>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<% if (path.startsWith('/admin')) { %>
<body class="admin-body">
  <main class="admin-root">
<% } else { %>
<body>
  <header class="site-header">
    <div class="header-main-row">
      <a class="brand" href="/" aria-label="ITESICWS inicio">
        <img class="brand-logo" data-theme-image data-light-src="/images/logos/logo-light.svg" data-dark-src="/images/logos/logo-dark.svg" src="/images/logos/logo-light.svg" alt="ITESICWS">
      </a>
      <nav>
        <a href="/" class="<%= path==='/'?'active':'' %>">Inicio</a>
        <a href="/productos" class="<%= path.startsWith('/productos')?'active':'' %>">Productos</a>
        <a href="/consultoria-ia" class="<%= path==='/consultoria-ia'?'active':'' %>">Consultoría IA</a>
        <a href="/blog" class="nav-blog-button <%= path.startsWith('/blog')?'active':'' %>">Blog</a>
        <a href="/#servicios">Servicios</a>
        <a href="/#contacto">Contacto</a>
        <% if (user) { %><a href="/admin">Admin</a><% } %>
      </nav>
      <button class="mobile-nav-toggle" type="button" data-mobile-nav aria-label="Abrir menú">☰</button>
      <button class="theme-toggle" type="button" data-theme-toggle aria-label="Cambiar tema">◐</button>
    </div>
  </header>
  <main>
<% } %>
